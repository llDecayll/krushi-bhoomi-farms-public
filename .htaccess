# ============================================================
#  Krushi Bhoomi Farms - Apache configuration
#  Clean URLs (no .html), redirects, and sensible defaults
# ============================================================

# Default document + no directory listing
DirectoryIndex index.html
Options -Indexes +FollowSymLinks

RewriteEngine On

# --- 1. Send /index and /index.html to the site root --------------
RewriteCond %{THE_REQUEST} \s/+index(?:\.html)?[\s?] [NC]
RewriteRule ^ / [R=301,L]

# --- 2. Redirect any /page.html request to the clean /page URL ----
RewriteCond %{THE_REQUEST} \s/+([^\s?]+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,NE,L]

# --- 3. Drop a trailing slash (except on real directories) --------
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+?)/+$ /$1 [R=301,L]

# --- 4. Internally serve /page from page.html ---------------------
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# Custom 404 page
ErrorDocument 404 /404.html

# ============================================================
#  Hardening & performance  (all guarded by IfModule)
# ============================================================

# Block access to hidden files/folders (.git, .htaccess, .DS_Store, …)
RewriteRule (^|/)\. - [F]

# Gzip-compress text assets
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain \
    application/javascript application/json image/svg+xml
</IfModule>

# Cache static assets aggressively, HTML briefly
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"
  ExpiresByType image/vnd.microsoft.icon  "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType application/manifest+json "access plus 1 week"
  ExpiresByType text/html                 "access plus 1 hour"
</IfModule>
